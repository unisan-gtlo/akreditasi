# ==========================================
# SIAKRED - Environment Variables Template
# Copy file ini jadi .env lalu isi nilainya
# ==========================================

# Django Settings
SECRET_KEY=ganti-dengan-secret-key-minimal-50-karakter-acak
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,akreditasi.unisan-g.id

# Database Schema Akreditasi
DB_NAME=unisan_db
DB_USER=postgres
DB_PASSWORD=dbIchsan@2025
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=akreditasi

# SSO Integration
SSO_BASE_URL=https://sso.unisan-g.id
SSO_SECRET_KEY=secret-sso-yang-sama-dengan-portal-sso
SSO_COOKIE_DOMAIN=.unisan-g.id

# SIMDA Integration (cross-schema)
SIMDA_SCHEMA=master

# Site
SITE_URL=http://localhost:8000
SITE_NAME=SIAKRED UNISAN

# Media & Static
MEDIA_ROOT=media
STATIC_ROOT=staticfiles

# LibreOffice path (untuk preview dokumen Office)
# Windows: C:\Program Files\LibreOffice\program\soffice.exe
# Linux: /usr/bin/soffice
LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe

# Max upload size (dalam MB)
MAX_UPLOAD_SIZE_MB=50
